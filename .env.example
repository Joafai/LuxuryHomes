# Gmail SMTP — used by app/api/contact/route.ts to deliver booking form
# submissions. The route returns 500 if any of these are missing.

# Sender Gmail address.
GMAIL_USER=your-email@gmail.com

# App Password (NOT your account password).
# Generate at https://myaccount.google.com/apppasswords — requires 2FA enabled.
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Where booking notifications are delivered.
CONTACT_EMAIL=where-you-receive-leads@example.com
